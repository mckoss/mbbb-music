{
  "name": "mbbb-music",
  "version": "0.1.0",
  "private": true,
  "description": "Mutiny Bay Brass Band music library tooling. Phase 1: Google Drive asset sync.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mbbb-sync": "bin/sync.js",
    "mbbb-library": "bin/library.js"
  },
  "scripts": {
    "sync": "node bin/sync.js",
    "sync:demo": "node bin/sync.js --fixture",
    "library": "node bin/library.js",
    "test": "node --test test/*.test.js",
    "dev": "vite dev",
    "build": "vite build",
    "start": "node build",
    "preview": "node scripts/preview.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "google-auth-library": "9.15.1",
    "pdfjs-dist": "6.0.227"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/enhanced-img": "0.10.4",
    "@sveltejs/kit": "2.63.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.9.2",
    "svelte": "5.56.2",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
