.DS_Store
node_modules/

# SvelteKit build artifacts and generated types.
.svelte-kit/
build/
vite.config.ts.timestamp-*

# Local sync config: Drive folder ids + Google credentials. Never committed.
# (config.example.json documents the shape and IS committed.)
config.json
config.json.bak

# Private music assets must not be committed to this public repository.
music/
assets/private/
generated/

# Phase 1 Drive sync target: local/private rebuildable storage (manifest + assets).
data/

# In a git worktree, the gitignored paths (node_modules, data) are SYMLINKS into
# the main checkout, not directories — and a trailing-slash pattern matches only
# directories, NOT a symlink. Without these anchored, name-only forms a careless
# `git add -A` in a worktree stages the symlink itself; merged to the main
# checkout it then overwrites the real directory with a self-referential link.
# (config.json above is already a no-slash pattern, so its symlink was safe.)
/node_modules
/data

# Throwaway sandbox for --fixture demo runs (kept away from real data/).
tmp/

# Playwright: browser artifacts and the isolated e2e data dir (seeded per run
# from e2e/fixtures/ by e2e/global-setup.ts). The committed fixtures stay.
/test-results/
/playwright-report/
/blob-report/
/e2e/.data/

